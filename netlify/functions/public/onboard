<script>
const API = 'https://marketingplan.astroaibots.com/api';
let agencyId = '', agencyConfig = {};

// Get agencyId from URL: /onboard/agency-id
async function init() {
  document.getElementById('loading').classList.add('show');
  const parts = window.location.pathname.split('/').filter(Boolean);
  agencyId = parts[parts.length - 1];

  if (!agencyId || agencyId === 'onboard') {
    document.getElementById('loading').classList.remove('show');
    document.getElementById('main').style.display = 'block';
    return;
  }

  try {
    const res  = await fetch(API + '/agency/public?id=' + encodeURIComponent(agencyId));
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || 'Agency not found');
    agencyConfig = data;
    applyBranding(data);
  } catch(e) {
    console.warn('Agency config load failed:', e.message);
    // Fallback to defaults
    agencyConfig = { name:'Astro AI', brandName:'Astro AI', brandColor:'#00d9a3', termsText:'By submitting this form you authorize the agency to create and manage digital marketing campaigns on your behalf.' };
  }

  document.getElementById('loading').classList.remove('show');
  document.getElementById('main').style.display = 'block';
}

function applyBranding(cfg) {
  document.documentElement.style.setProperty('--brand', cfg.brandColor || '#00d9a3');
  document.getElementById('header-brand').textContent = cfg.brandName || cfg.name || '';
  document.getElementById('header-title').textContent = cfg.onboardingTitle || 'Get Your AI Marketing Plan';
  if (cfg.welcomeMsg) document.getElementById('header-sub').textContent = cfg.welcomeMsg;
  document.title = cfg.onboardingTitle || cfg.brandName || 'Get Your Marketing Plan';
  document.getElementById('terms-text').textContent = cfg.termsText || 'By submitting this form you authorize the agency to create and manage digital marketing campaigns on your behalf.';
}

function v(id) { return (document.getElementById(id)?.value||'').trim(); }
function getSelected(groupId) { return [...document.querySelectorAll(`#${groupId} .selected`)].map(el=>el.textContent).join(', '); }
function selectOne(el,groupId) { document.querySelectorAll(`#${groupId} .cb-option`).forEach(e=>e.classList.remove('selected')); el.classList.add('selected'); }
function toggleMulti(el) { el.classList.toggle('selected'); }

let currentStep = 1;
function goStep(n) {
  // Validate before advancing
  if (n > currentStep) {
    const err = validate(currentStep);
    if (err) { showErr(currentStep, err); return; }
    clearErr(currentStep);
  }
  document.getElementById('step-'+currentStep).style.display = 'none';
  document.getElementById('tab-'+currentStep).classList.remove('active');
  if (currentStep < n) document.getElementById('tab-'+currentStep).classList.add('done');
  currentStep = n;
  document.getElementById('step-'+n).style.display = 'block';
  document.getElementById('tab-'+n).classList.add('active');
  document.getElementById('progress').style.width = (n * 25) + '%';
  if (n === 4) buildReview();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function validate(step) {
  if (step === 1) {
    if (!v('f-biz'))      return 'Business name is required.';
    if (!v('f-industry')) return 'Please select an industry.';
    if (!v('f-service'))  return 'Primary service is required.';
  }
  if (step === 2) {
    if (!v('f-goal'))   return 'Please describe your 90-day goal.';
    if (!v('f-budget')) return 'Please select your monthly budget.';
    if (!getSelected('platforms')) return 'Please select at least one ad platform.';
  }
  if (step === 3) {
    if (!v('f-fn'))    return 'First name is required.';
    if (!v('f-ln'))    return 'Last name is required.';
    if (!v('f-email')) return 'Email is required.';
    if (!v('f-email').includes('@')) return 'Enter a valid email address.';
  }
  return null;
}

function showErr(step, msg) { const el = document.getElementById('step'+step+'-err'); if(el){el.textContent=msg;el.style.display='block';} }
function clearErr(step) { const el = document.getElementById('step'+step+'-err'); if(el)el.style.display='none'; }

function buildReview() {
  const rows = [
    ['Business', v('f-biz')],
    ['Industry', v('f-industry')],
    ['Service', v('f-service')],
    ['Service Area', [getSelected('area-type'), v('f-area')].filter(Boolean).join(' — ')],
    ['90-Day Goal', v('f-goal')],
    ['Monthly Budget', '$'+v('f-budget')+'/mo'],
    ['Platforms', getSelected('platforms')],
    ['Contact', `${v('f-fn')} ${v('f-ln')} · ${v('f-email')}${v('f-phone') ? ' · '+v('f-phone') : ''}`],
  ];
  document.getElementById('review-content').innerHTML = rows
    .filter(r=>r[1])
    .map(r=>`<div style="display:flex;gap:12px;padding:6px 0;border-bottom:1px solid #f0f2f7"><div style="font-weight:700;color:#333;min-width:120px">${r[0]}</div><div>${r[1]}</div></div>`)
    .join('');
}

async function submitForm() {
  if (!document.getElementById('terms-cb').checked) {
    const el = document.getElementById('step4-err');
    el.textContent = 'You must agree to the terms to continue.'; el.style.display = 'block';
    return;
  }

  // Show generating screen
  document.getElementById('step-4').style.display = 'none';
  document.getElementById('generating').classList.add('show');

  const msgs = [
    'Analyzing your business and market...',
    'Writing 5 ad angles with multiple variations...',
    'Building your 90-day roadmap...',
    'Crafting audience targeting strategy...',
    'Generating qualification script...',
    'Finalizing your plan...',
  ];
  let mi = 0;
  const genMsg = document.getElementById('gen-msg');
  const msgInterval = setInterval(() => { if(mi < msgs.length-1) genMsg.textContent = msgs[++mi]; }, 18000);

  try {
    const payload = {
      agencyId,
      firstName:       v('f-fn'),
      lastName:        v('f-ln'),
      email:           v('f-email'),
      phone:           v('f-phone'),
      businessName:    v('f-biz'),
      industry:        v('f-industry'),
      primaryService:  v('f-service'),
      website:         v('f-website'),
      companySize:     v('f-size'),
      serviceAreaType: getSelected('area-type'),
      serviceDetails:  v('f-area'),
      goal90Days:      v('f-goal'),
      adBudget:        v('f-budget'),
      adPlatforms:     getSelected('platforms'),
    };

    const res  = await fetch(API + '/agency/process-plan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await res.json();
    clearInterval(msgInterval);
    document.getElementById('generating').classList.remove('show');

    if (!res.ok || !data.success) throw new Error(data.error || 'Plan generation failed');

    // Show success
    document.getElementById('step-4').style.display = 'none';
    const ss = document.getElementById('success-screen');
    ss.classList.add('show');
    if (data.planUrl) {
      const pb = document.getElementById('success-plan-btn');
      pb.href = data.planUrl; pb.style.display = 'inline-flex';
    }
    if (data.portalUrl) {
      document.getElementById('success-portal-btn').href = data.portalUrl;
    }

  } catch(e) {
    clearInterval(msgInterval);
    document.getElementById('generating').classList.remove('show');
    document.getElementById('step-4').style.display = 'block';
    const el = document.getElementById('step4-err');
    el.textContent = '❌ ' + e.message; el.style.display = 'block';
  }
}

init();
</script>

</body>

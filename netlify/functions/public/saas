        <div class="field"><label>Your Full Name *</label><input id="s-name" placeholder="Jane Smith"></div>
      </div>
      <div class="field"><label>Email Address *</label><input id="s-email" type="email" placeholder="you@agency.com"></div>
      <div class="form-row">
        <div class="field"><label>Phone</label><input id="s-phone" type="tel" placeholder="(512) 555-0000"></div>
        <div class="field"><label>Website</label><input id="s-site" placeholder="agency.com"></div>
      </div>
      <div class="field"><label>Password * (min 8 chars)</label><input id="s-pw" type="password" placeholder="••••••••"></div>
      <div class="form-err" id="s-err"></div>
      <div class="form-footer">
        <button class="btn btn-teal btn-lg" style="width:100%" onclick="submitSignup()" id="s-btn">Create My Agency →</button>
        <p class="form-note">No credit card required. By signing up you agree to our <a href="#" style="color:var(--teal)">Terms of Service</a>.</p>
      </div>
    </div>
    <div class="success-box" id="signup-success">
      <div style="font-size:2rem;margin-bottom:8px">🎉</div>
      <h3>Your Agency is Live!</h3>
      <p style="font-size:.83rem;color:var(--muted);margin:8px 0 16px">Check your email for login details. Bookmark your links:</p>
      <a class="success-link" id="succ-dashboard" href="#" target="_blank">📊 Agency Dashboard →</a>
      <a class="success-link" id="succ-onboard" href="#" target="_blank">📋 Client Onboarding Form →</a>
      <button class="btn btn-teal" style="margin-top:16px;width:100%" onclick="goToDashboard()">Open My Dashboard →</button>
    </div>
  </div>
</div>

<!-- LOGIN MODAL -->

<div class="modal-bg" id="login-modal" onclick="if(event.target===this)closeLogin()">
  <div class="modal">
    <h2>🔐 Agency Login</h2>
    <p>Enter your agency ID and password to access your dashboard.</p>
    <div class="field"><label>Agency ID</label><input id="l-id" placeholder="your-agency-name-abc123"></div>
    <div class="field"><label>Password</label><input id="l-pw" type="password" placeholder="••••••••"></div>
    <div class="form-err" id="l-err"></div>
    <div class="form-footer">
      <button class="btn btn-teal" style="width:100%" onclick="submitLogin()" id="l-btn">Log In →</button>
    </div>
  </div>
</div>

<script>
const API = 'https://marketingplan.astroaibots.com/api';

function openSignup()  { document.getElementById('signup-modal').classList.add('open'); }
function closeSignup() { document.getElementById('signup-modal').classList.remove('open'); }
function openLoginPrompt() { document.getElementById('login-modal').classList.add('open'); }
function closeLogin()  { document.getElementById('login-modal').classList.remove('open'); }

let createdDashUrl = '', createdOnbUrl = '', createdAgencyId = '';

async function submitSignup() {
  const agency = v('s-agency'), name = v('s-name'), email = v('s-email'), pw = v('s-pw');
  const err = s => { const el = document.getElementById('s-err'); el.textContent = s; el.style.display = 'block'; };

  if (!agency || !name || !email || !pw) return err('Please fill in all required fields.');
  if (pw.length < 8) return err('Password must be at least 8 characters.');
  if (!email.includes('@')) return err('Enter a valid email address.');

  const btn = document.getElementById('s-btn');
  btn.textContent = '⏳ Creating...'; btn.disabled = true;
  document.getElementById('s-err').style.display = 'none';

  try {
    const res  = await fetch(API + '/agency/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ agencyName: agency, ownerName: name, ownerEmail: email, password: pw, phone: v('s-phone'), website: v('s-site') }),
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Registration failed');

    createdDashUrl  = data.dashboardUrl;
    createdOnbUrl   = data.onboardingUrl;
    createdAgencyId = data.agencyId;

    // Store token for redirect
    sessionStorage.setItem('saas_agency_id', data.agencyId);

    document.getElementById('signup-form-wrap').style.display = 'none';
    document.getElementById('signup-success').style.display = 'block';
    document.getElementById('succ-dashboard').href = createdDashUrl;
    document.getElementById('succ-dashboard').textContent = '📊 Agency Dashboard → ' + createdDashUrl;
    document.getElementById('succ-onboard').href = createdOnbUrl;
    document.getElementById('succ-onboard').textContent = '📋 Onboarding Form → ' + createdOnbUrl;

  } catch(e) {
    err(e.message);
    btn.textContent = 'Create My Agency →'; btn.disabled = false;
  }
}

function goToDashboard() {
  if (createdDashUrl) window.location.href = createdDashUrl;
}

async function submitLogin() {
  const id = v('l-id'), pw = v('l-pw');
  const err = s => { const el = document.getElementById('l-err'); el.textContent = s; el.style.display = 'block'; };
  if (!id || !pw) return err('Agency ID and password required.');
  const btn = document.getElementById('l-btn');
  btn.textContent = '⏳...'; btn.disabled = true;
  try {
    const res  = await fetch(API + '/agency/login', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ agencyId: id, password: pw }),
    });
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Login failed');
    sessionStorage.setItem('saas_token', data.token);
    sessionStorage.setItem('saas_agency_id', data.agencyId);
    window.location.href = `https://marketingplan.astroaibots.com/saas-dashboard.html`;
  } catch(e) {
    err(e.message); btn.textContent = 'Log In →'; btn.disabled = false;
  }
}

function v(id) { return (document.getElementById(id)?.value || '').trim(); }
</script>


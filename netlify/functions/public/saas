<!-- SIGNUP MODAL -->

<div class="modal-bg" id="signup-modal" onclick="if(event.target===this)closeSignup()">
  <div class="modal">
    <div id="signup-form-wrap">
      <h2>🚀 Create Your Agency</h2>
